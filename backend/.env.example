# ========================================
# RT Finance Hub — Backend Environment
# ========================================

# Server
PORT=8080
GIN_MODE=debug

# Database PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=rt_finance
DB_SSLMODE=disable

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE_HOURS=24

# File Upload
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=5242880

# CORS
CORS_ORIGIN=http://localhost:5173
