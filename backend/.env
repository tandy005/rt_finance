# ========================================
# RT Finance Hub — Backend Environment
# Salin file ini menjadi .env dan sesuaikan
# ========================================

# Server Configuration
PORT=8080
GIN_MODE=debug

# Database PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=rt_finance
DB_SSLMODE=disable

# JWT Configuration
JWT_SECRET=rt_finance_super_secret_jwt_key_2024_change_this
JWT_EXPIRE_HOURS=24

# File Upload
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=5242880

# CORS (Frontend URL)
CORS_ORIGIN=http://localhost:5173
